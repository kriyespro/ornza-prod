{% extends "base.jinja" %}

{% block title %}Login · ORNZA{% endblock %}
{% block body_class %}has-site-header nav-solid{% endblock %}

{% block content %}
<main class="pt-32 pb-16 px-4 min-h-screen flex items-center justify-center">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <a href="{{ url('store:home') }}" class="font-display text-2xl text-espresso no-underline tracking-[0.15em]">ORN<span class="text-gold italic">Z</span>A</a>
      <p class="text-xs text-taupe mt-2 tracking-wider uppercase">Welcome Back</p>
    </div>

    <div class="bg-white border border-gold/15 rounded-lg p-8 shadow-sm">
      {% if error %}
      <div class="bg-red-50 border border-red-200 text-red-700 text-sm px-4 py-3 rounded mb-6">{{ error }}</div>
      {% endif %}

      <form method="post" action="{{ url('users:login') }}">
        {{ csrf_input }}
        <input type="hidden" name="next" value="{{ request.GET.get('next', '') }}">

        <div class="mb-5">
          <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe mb-2">Username or Email</label>
          <input type="text" name="username" required class="w-full border border-gold/25 rounded px-4 py-3 text-sm text-espresso outline-none focus:border-gold transition-colors">
        </div>
        <div class="mb-6">
          <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe mb-2">Password</label>
          <input type="password" name="password" required class="w-full border border-gold/25 rounded px-4 py-3 text-sm text-espresso outline-none focus:border-gold transition-colors">
        </div>
        <button type="submit" class="w-full bg-espresso text-gold py-3.5 text-[10px] font-bold tracking-[0.2em] uppercase rounded transition-all hover:bg-gold hover:text-espresso">
          Sign In
        </button>
      </form>

      <p class="text-center text-xs text-taupe mt-6">
        Don't have an account?
        <a href="{{ url('users:register') }}" class="text-gold-deep no-underline hover:underline">Create one</a>
      </p>
    </div>
  </div>
</main>
{% endblock %}
