{% extends "base.jinja" %}
{% block title %}My Addresses · ORNZA{% endblock %}
{% block body_class %}has-site-header nav-solid{% endblock %}

{% block content %}
<main class="pt-28 pb-16 px-4 md:px-8 max-w-3xl mx-auto">
  <div class="flex items-center gap-4 mb-8">
    <a href="{{ url('users:dashboard') }}" class="text-taupe hover:text-gold-deep text-xs no-underline">← Dashboard</a>
    <div>
      <div class="text-[9px] tracking-[0.3em] uppercase text-gold mb-0.5">Account</div>
      <h1 class="font-display text-2xl text-espresso font-light">Saved Addresses</h1>
    </div>
  </div>

  {% if addresses %}
  <div class="space-y-4 mb-8">
    {% for addr in addresses %}
    <div class="bg-white border border-gold/15 rounded-lg p-5 {% if addr.is_default %}border-gold/40{% endif %}">
      <div class="flex justify-between items-start">
        <div>
          {% if addr.is_default %}<span class="text-[9px] uppercase tracking-wide text-gold font-semibold block mb-1">Default Address</span>{% endif %}
          <div class="font-medium text-espresso text-sm">{{ addr.full_name }}</div>
          <div class="text-sm text-taupe mt-1">{{ addr.line1 }}{% if addr.line2 %}, {{ addr.line2 }}{% endif %}</div>
          <div class="text-sm text-taupe">{{ addr.city }}, {{ addr.state }} - {{ addr.pincode }}</div>
          <div class="text-sm text-taupe mt-1">📞 {{ addr.phone }}</div>
        </div>
        <form method="post" action="{{ url('users:address_delete', pk=addr.pk) }}">
          {{ csrf_input }}
          <button type="submit" class="text-xs text-red-400 hover:text-red-600 bg-transparent border-0 cursor-pointer" onclick="return confirm('Delete this address?')">Delete</button>
        </form>
      </div>
    </div>
    {% endfor %}
  </div>
  {% endif %}

  <!-- Add Address Form -->
  <div class="bg-white border border-gold/15 rounded-lg p-6" x-data="{ open: {% if not addresses %}true{% else %}false{% endif %} }">
    <button @click="open = !open" type="button" class="flex items-center gap-2 text-espresso font-medium text-sm mb-0 w-full bg-transparent border-0 cursor-pointer">
      <span x-text="open ? '−' : '+'" class="text-gold text-lg leading-none"></span>
      Add New Address
    </button>
    <form method="post" action="{{ url('users:address_add') }}" x-show="open" x-transition class="mt-5">
      {{ csrf_input }}
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
        <div><label class="block text-[10px] tracking-[0.2em] uppercase text-taupe mb-2">Full Name *</label><input type="text" name="full_name" required class="w-full border border-gold/25 rounded px-4 py-3 text-sm text-espresso outline-none focus:border-gold"></div>
        <div><label class="block text-[10px] tracking-[0.2em] uppercase text-taupe mb-2">Phone *</label><input type="tel" name="phone" required class="w-full border border-gold/25 rounded px-4 py-3 text-sm text-espresso outline-none focus:border-gold"></div>
      </div>
      <div class="mb-4"><label class="block text-[10px] tracking-[0.2em] uppercase text-taupe mb-2">Address Line 1 *</label><input type="text" name="line1" required class="w-full border border-gold/25 rounded px-4 py-3 text-sm text-espresso outline-none focus:border-gold"></div>
      <div class="mb-4"><label class="block text-[10px] tracking-[0.2em] uppercase text-taupe mb-2">Address Line 2</label><input type="text" name="line2" class="w-full border border-gold/25 rounded px-4 py-3 text-sm text-espresso outline-none focus:border-gold"></div>
      <div class="grid grid-cols-3 gap-4 mb-4">
        <div><label class="block text-[10px] tracking-[0.2em] uppercase text-taupe mb-2">City *</label><input type="text" name="city" required class="w-full border border-gold/25 rounded px-4 py-3 text-sm text-espresso outline-none focus:border-gold"></div>
        <div><label class="block text-[10px] tracking-[0.2em] uppercase text-taupe mb-2">State *</label><input type="text" name="state" required class="w-full border border-gold/25 rounded px-4 py-3 text-sm text-espresso outline-none focus:border-gold"></div>
        <div><label class="block text-[10px] tracking-[0.2em] uppercase text-taupe mb-2">Pincode *</label><input type="text" name="pincode" required class="w-full border border-gold/25 rounded px-4 py-3 text-sm text-espresso outline-none focus:border-gold"></div>
      </div>
      <label class="flex items-center gap-2 text-sm text-taupe mb-5 cursor-pointer">
        <input type="checkbox" name="is_default" class="rounded"> Set as default address
      </label>
      <button type="submit" class="bg-espresso text-gold py-3 px-8 text-[10px] font-bold tracking-[0.2em] uppercase rounded transition-all hover:bg-gold hover:text-espresso">Save Address</button>
    </form>
  </div>
</main>
{% endblock %}
