{% extends "base.jinja" %}

{% block title %}Customer Reviews · ORNZA Jewellery{% endblock %}
{% block body_class %}has-site-header has-hero{% endblock %}

{% block content %}

<!-- Hero -->
<div class="reviews-page-hero">
  <div style="position:relative;z-index:1;">
    <div style="font-size:9px;letter-spacing:0.35em;text-transform:uppercase;color:#C9A84C;margin-bottom:16px;font-weight:500;">500+ Happy Customers</div>
    <h1 style="font-family:'Playfair Display',serif;font-size:clamp(36px,6vw,64px);font-weight:300;color:#FFFFF0;letter-spacing:0.06em;margin-bottom:16px;">Customer <em style="color:#C9A84C;">Reviews</em></h1>
    <p style="font-size:13px;color:rgba(232,213,160,0.6);font-weight:300;max-width:500px;margin:0 auto;line-height:1.7;">Real words from real ORNZA customers. We're humbled by every piece of feedback that inspires us to craft better.</p>
    <div style="display:flex;justify-content:center;gap:3px;margin-top:24px;">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="#C9A84C"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="#C9A84C"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="#C9A84C"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="#C9A84C"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="#C9A84C"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      <span style="font-size:14px;color:rgba(232,213,160,0.7);margin-left:8px;font-weight:300;">4.9 / 5.0</span>
    </div>
  </div>
</div>

<!-- Stats Bar -->
<div class="reviews-stats-bar">
  <div class="stat-block"><span class="stat-num">4.9</span><div class="stat-label">Overall Rating</div></div>
  <div class="stat-block"><span class="stat-num">500+</span><div class="stat-label">Total Reviews</div></div>
  <div class="stat-block"><span class="stat-num">98%</span><div class="stat-label">Recommend Us</div></div>
  <div class="stat-block"><span class="stat-num">100%</span><div class="stat-label">Verified Purchases</div></div>
</div>

<!-- Filter Bar (Alpine.js) -->
<div class="reviews-filter-bar" x-data="{ active: 'all' }">
  <button class="filter-btn" :class="{ 'active': active === 'all' }" @click="active='all'; filterReviews('all')" type="button">All Reviews</button>
  <button class="filter-btn" :class="{ 'active': active === 'women' }" @click="active='women'; filterReviews('women')" type="button">Women's</button>
  <button class="filter-btn" :class="{ 'active': active === 'men' }" @click="active='men'; filterReviews('men')" type="button">Men's</button>
  <button class="filter-btn" :class="{ 'active': active === 'silver' }" @click="active='silver'; filterReviews('silver')" type="button">925 Silver</button>
  <button class="filter-btn" :class="{ 'active': active === 'hamper' }" @click="active='hamper'; filterReviews('hamper')" type="button">Hampers</button>
</div>

{% set star = '<svg viewBox="0 0 24 24" fill="#C9A84C" width="14" height="14"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>' %}

<!-- Reviews Grid -->
<div class="reviews-masonry" id="reviews-container">

  {% set reviews_data = [
    ('women', 'Mangalsutra', 5, 'The mangalsutra I ordered is absolutely stunning. The gold plating is so rich and the black beads are perfectly uniform. I\'ve received so many compliments. Even my mother-in-law who\'s very traditional approved of it!', 'Priya Sharma', 'Mumbai', '2 weeks ago', 'P', 'linear-gradient(135deg,#8b4513,#C9A84C)'),
    ('men', 'Men\'s Cuban Chain', 5, 'Bought the Miami Cuban link chain for myself. Honestly this is incredible quality for the price. Heavy, shiny, and has not tarnished even after 3 months of daily wear. Will definitely be ordering more.', 'Rahul Mehta', 'Surat', '1 month ago', 'R', 'linear-gradient(135deg,#8B6914,#C9A84C)'),
    ('silver', '925 Silver Ring', 5, 'I have very sensitive skin and most jewellery causes reactions. The 925 silver ring from ORNZA is the first ring I\'ve worn for weeks without any rash or discomfort. Highly recommended for sensitive skin!', 'Ananya Patel', 'Ahmedabad', '3 weeks ago', 'A', 'linear-gradient(135deg,#6b6b8b,#9090b0)'),
    ('hamper', 'Anniversary Gold Hamper', 5, 'Gifted my wife the Anniversary Gold Hamper for our 5th anniversary. The packaging alone made her emotional — the calligraphy note was so personal. The jewellery inside was beautiful. ORNZA really knows how to make a moment special.', 'Vivek Joshi', 'Pune', '1 week ago', 'V', 'linear-gradient(135deg,#7a5c00,#C9A84C)'),
    ('women', 'Pearl Collection', 5, 'The pearl necklace is absolutely gorgeous. The pearls have a beautiful lustre and the gold clasp is well-made. It looks so much more expensive than what I paid. Wore it to a wedding and everyone kept asking where I got it from!', 'Nisha Kapoor', 'Delhi', '2 months ago', 'N', 'linear-gradient(135deg,#8b4513,#C9A84C)'),
    ('women', 'CZ Tennis Bracelet', 5, 'The CZ bracelet catches the light beautifully! Every stone is set perfectly — no loose ones at all. I\'ve been wearing it daily for over 6 weeks and it still looks brand new. Packaging was also super premium.', 'Sneha Reddy', 'Hyderabad', '3 weeks ago', 'S', 'linear-gradient(135deg,#5c3d8b,#9370cc)'),
    ('men', 'Men\'s Signet Ring', 4, 'Ordered the signet ring as a birthday gift for my brother. He absolutely loves it. The gold plating is very even and the ring feels substantial. Delivery was also very fast — 2 days only!', 'Meera Iyer', 'Chennai', '1 month ago', 'M', 'linear-gradient(135deg,#1a4b3a,#2d8a6a)'),
    ('hamper', 'Birthday Sparkle Hamper', 5, 'I surprised my best friend with the Birthday Sparkle Hamper. She literally cried when she opened the box! The presentation is SO premium — you\'d think it\'s from a high-end boutique. Worth every rupee.', 'Divya Nair', 'Bangalore', '5 days ago', 'D', 'linear-gradient(135deg,#8b1a6b,#cc4b9d)'),
    ('silver', '925 Silver Hoop Set', 5, 'I bought the silver hoop set (3 sizes) and I wear them every single day now. They\'re lightweight, shiny, and the silver quality is clearly genuine. My earring holes haven\'t reacted at all. 5 stars without hesitation!', 'Kavya Singh', 'Jaipur', '2 weeks ago', 'K', 'linear-gradient(135deg,#4a6b8b,#6b9fcc)'),
  ] %}

  {% for cat, product, rating, text, name, city, when, initial, avatar_bg in reviews_data %}
  <div class="review-tile" data-cat="{{ cat }}">
    <div class="review-tile-product">◆ {{ product }}</div>
    <div class="review-tile-quote">"</div>
    <div class="review-tile-stars">
      {% for i in range(rating) %}
      <svg viewBox="0 0 24 24" fill="#C9A84C" width="13" height="13"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      {% endfor %}
      {% for i in range(5 - rating) %}
      <svg viewBox="0 0 24 24" fill="rgba(201,168,76,0.2)" width="13" height="13"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      {% endfor %}
    </div>
    <div class="review-tile-text">{{ text }}</div>
    <div class="review-tile-footer">
      <div class="review-tile-avatar" style="background:{{ avatar_bg }};">{{ initial }}</div>
      <div>
        <div class="review-tile-name">{{ name }}</div>
        <div class="review-tile-meta">{{ city }} · {{ when }}</div>
        <div class="review-tile-verified">✔ Verified Purchase</div>
      </div>
    </div>
  </div>
  {% endfor %}

</div>

<!-- Write a Review -->
<div class="write-review-section">
  <div style="font-size:9px;letter-spacing:0.3em;text-transform:uppercase;color:#C9A84C;margin-bottom:12px;">Share Your Experience</div>
  <h2 style="font-family:'Playfair Display',serif;font-size:clamp(26px,4vw,40px);font-weight:300;color:#FFFFF0;letter-spacing:0.06em;margin-bottom:8px;">Write a Review</h2>
  <p style="font-size:13px;color:rgba(232,213,160,0.55);font-weight:300;margin-bottom:32px;">Your feedback helps us improve and helps other customers make better choices.</p>

  {% if request.user.is_authenticated %}
  <form class="review-form" method="post" action="{{ url('store:reviews') }}">
    {{ csrf_input }}
    <div class="form-grid">
      <div class="form-group"><label>Product Purchased</label><input type="text" name="product_name" class="form-input" placeholder="e.g. Pearl Necklace"></div>
    </div>
    <div class="form-group" style="margin-bottom:16px;"><label>Your Review</label><textarea name="body" class="form-input form-textarea" placeholder="Tell us about your experience with the product, quality, packaging, and delivery..."></textarea></div>
    <button class="form-submit-btn" type="submit">Submit Review</button>
  </form>
  {% else %}
  <div class="ornza-tw text-center">
    <p class="text-sm text-champagne/60 mb-4">Please sign in to write a review.</p>
    <a href="{{ url('users:login') }}" class="inline-flex items-center gap-2 bg-gold text-espresso text-[10px] font-bold tracking-[0.2em] uppercase px-6 py-3 rounded-sm no-underline hover:bg-gold-light transition-colors">Sign In to Review</a>
  </div>
  {% endif %}
</div>

<a href="https://wa.me/919999999999" class="wa-sticky-btn" target="_blank" aria-label="Chat on WhatsApp">
  <svg viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
  <span class="wa-tooltip">Chat with us</span>
</a>

{% endblock %}

{% block extra_scripts %}
<script>
function filterReviews(cat) {
  document.querySelectorAll('.review-tile').forEach(el => {
    el.style.display = (cat === 'all' || el.dataset.cat === cat) ? '' : 'none';
  });
}
</script>
{% endblock %}
