{% extends "control/base_control.jinja" %}
{% block title %}Users{% endblock %}
{% block page_title %}User Manager{% endblock %}

{% block content %}
<!-- Search -->
<div class="mb-5 flex items-center gap-3">
  <form action="{{ url('control:users') }}" method="get" class="flex items-center gap-2 flex-1 max-w-sm">
    <input type="text" name="q" value="{{ request.GET.get('q', '') }}"
      placeholder="Search by username or email..."
      class="flex-1 border border-gray-200 rounded-lg px-4 py-2.5 text-sm outline-none focus:border-blue-400"
      hx-get="{{ url('control:users') }}"
      hx-target="#users-table"
      hx-trigger="keyup changed delay:400ms"
      hx-include="this">
    <button type="submit" class="bg-gray-800 text-white text-xs px-4 py-2.5 rounded-lg">Search</button>
  </form>
  <div class="text-xs text-gray-500">{{ users|length }} users</div>
</div>

<!-- Table -->
<div class="bg-white rounded-xl border border-gray-200 overflow-hidden" id="users-table">
  <table class="w-full text-sm">
    <thead>
      <tr class="text-[10px] tracking-wider uppercase text-gray-400 border-b border-gray-100 bg-gray-50">
        <th class="text-left px-5 py-3">User</th>
        <th class="text-left px-5 py-3">Email</th>
        <th class="text-left px-5 py-3">Joined</th>
        <th class="text-left px-5 py-3">Orders</th>
        <th class="text-left px-5 py-3">Status</th>
        <th class="text-right px-5 py-3">Action</th>
      </tr>
    </thead>
    <tbody>
      {% for u in users %}
      <tr class="border-b border-gray-50 hover:bg-gray-50 transition-colors">
        <td class="px-5 py-3">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-gold to-espresso flex items-center justify-center text-white text-xs font-bold flex-shrink-0">
              {{ u.username[0]|upper }}
            </div>
            <div>
              <div class="font-medium text-gray-800 text-xs">{{ u.username }}</div>
              {% if u.get_full_name() %}<div class="text-[10px] text-gray-400">{{ u.get_full_name() }}</div>{% endif %}
            </div>
          </div>
        </td>
        <td class="px-5 py-3 text-xs text-gray-600">{{ u.email or '—' }}</td>
        <td class="px-5 py-3 text-xs text-gray-400">{{ u.date_joined.strftime('%d %b %Y') }}</td>
        <td class="px-5 py-3 text-xs text-gray-600">{{ u.orders.count() }}</td>
        <td class="px-5 py-3">
          {% if u.is_active %}
          <span class="text-[9px] uppercase tracking-wide px-2 py-1 rounded-full bg-green-100 text-green-700">Active</span>
          {% else %}
          <span class="text-[9px] uppercase tracking-wide px-2 py-1 rounded-full bg-red-100 text-red-700">Banned</span>
          {% endif %}
          {% if u.is_staff %}<span class="ml-1 text-[9px] uppercase tracking-wide px-2 py-1 rounded-full bg-blue-100 text-blue-700">Staff</span>{% endif %}
        </td>
        <td class="px-5 py-3 text-right">
          <a href="{{ url('control:user_detail', pk=u.pk) }}" class="text-xs text-blue-600 no-underline hover:underline">View →</a>
        </td>
      </tr>
      {% else %}
      <tr><td colspan="6" class="px-5 py-10 text-center text-gray-400 text-sm">No users found.</td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>

{% if is_paginated %}
<div class="flex justify-center gap-2 mt-5">
  {% if page_obj.has_previous() %}<a href="?page={{ page_obj.previous_page_number() }}" class="px-3 py-1.5 border border-gray-200 rounded text-xs text-gray-600 no-underline hover:border-gray-400">← Prev</a>{% endif %}
  <span class="px-3 py-1.5 text-xs text-gray-500">Page {{ page_obj.number }} / {{ page_obj.paginator.num_pages }}</span>
  {% if page_obj.has_next() %}<a href="?page={{ page_obj.next_page_number() }}" class="px-3 py-1.5 border border-gray-200 rounded text-xs text-gray-600 no-underline hover:border-gray-400">Next →</a>{% endif %}
</div>
{% endif %}
{% endblock %}
