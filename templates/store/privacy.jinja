{% extends "base.jinja" %}
{% block title %}Privacy Policy · ORNZA{% endblock %}
{% block body_class %}has-site-header nav-solid{% endblock %}
{% block content %}
<div class="page">
  <div class="page-header">
    <div class="badge">Legal</div>
    <h1 class="page-title">Privacy Policy</h1>
    <p class="page-desc">How ORNZA collects, uses, and protects your personal information.</p>
  </div>
  <div class="contact-section" style="max-width:760px;margin:0 auto 80px;">
    <div class="contact-info-panel" style="padding:32px;">
      <p class="showroom-detail" style="line-height:1.8;margin-bottom:20px;">Last updated: June 2026. ORNZA respects your privacy. This policy explains what data we collect when you shop, track orders, or contact us.</p>
      <h2 class="contact-block-title">Information We Collect</h2>
      <ul style="list-style:disc;padding-left:20px;color:var(--color-text-muted);line-height:1.9;font-size:14px;margin-bottom:20px;">
        <li>Name, email, phone, and delivery address at checkout</li>
        <li>Order history and payment method (we do not store card numbers)</li>
        <li>Newsletter email if you subscribe</li>
      </ul>
      <h2 class="contact-block-title">How We Use It</h2>
      <ul style="list-style:disc;padding-left:20px;color:var(--color-text-muted);line-height:1.9;font-size:14px;margin-bottom:20px;">
        <li>Process and deliver your orders</li>
        <li>Send order updates and support responses</li>
        <li>Improve our products and website experience</li>
      </ul>
      <h2 class="contact-block-title">Your Rights</h2>
      <p class="showroom-detail" style="line-height:1.8;">Request access, correction, or deletion of your data by emailing <a href="mailto:ornzza.com@gmail.com" style="color:var(--color-gold-deep);">ornzza.com@gmail.com</a>.</p>
    </div>
  </div>
</div>
{% endblock %}
