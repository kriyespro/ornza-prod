{% extends "base.jinja" %}
{% block title %}Terms of Service · ORNZA{% endblock %}
{% block body_class %}has-site-header nav-solid{% endblock %}
{% block content %}
<div class="page">
  <div class="page-header">
    <div class="badge">Legal</div>
    <h1 class="page-title">Terms of Service</h1>
    <p class="page-desc">Please read these terms carefully before using ORNZA.</p>
  </div>
  <div class="contact-section" style="max-width:760px;margin:0 auto 80px;">
    <div class="contact-info-panel" style="padding:32px;">
      <p class="showroom-detail" style="line-height:1.8;margin-bottom:20px;">Last updated: June 2026. By placing an order on ornza.com, you agree to the following terms.</p>
      <h2 class="contact-block-title">Orders &amp; Pricing</h2>
      <p class="showroom-detail" style="line-height:1.8;margin-bottom:20px;">All prices are in Indian Rupees (₹) and inclusive of GST. We reserve the right to refuse or cancel orders at our discretion. Prices are subject to change without notice.</p>
      <h2 class="contact-block-title">Product Descriptions</h2>
      <p class="showroom-detail" style="line-height:1.8;margin-bottom:20px;">We make every effort to display products accurately. Actual colours may vary slightly due to monitor settings. All jewellery is artificial (fashion jewellery) unless explicitly stated as 925 silver or hallmarked.</p>
      <h2 class="contact-block-title">Limitation of Liability</h2>
      <p class="showroom-detail" style="line-height:1.8;margin-bottom:20px;">ORNZA shall not be liable for indirect, incidental, or consequential damages arising from use of our products or services beyond the value of the order placed.</p>
      <h2 class="contact-block-title">Contact</h2>
      <p class="showroom-detail" style="line-height:1.8;">For questions about these terms, email <a href="mailto:ornzza.com@gmail.com" style="color:var(--color-gold-deep);">ornzza.com@gmail.com</a> or WhatsApp +91 99999 99999.</p>
    </div>
  </div>
</div>
{% endblock %}
