{% extends "control/base_control.jinja" %}
{% block title %}Products{% endblock %}
{% block page_title %}Products{% endblock %}

{% block content %}
<div class="flex items-center justify-between mb-5">
  <div class="text-sm text-gray-500">{{ products|length }} products</div>
  <a href="{{ url('control:product_add') }}" class="bg-gray-800 text-white text-xs px-4 py-2.5 rounded-lg no-underline hover:bg-gray-700">+ Add Product</a>
</div>

<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
  <table class="w-full text-sm">
    <thead>
      <tr class="text-[10px] tracking-wider uppercase text-gray-400 border-b border-gray-100 bg-gray-50">
        <th class="text-left px-5 py-3">Product</th>
        <th class="text-left px-5 py-3">Category</th>
        <th class="text-left px-5 py-3">Price</th>
        <th class="text-left px-5 py-3">Stock</th>
        <th class="text-left px-5 py-3">Status</th>
        <th class="text-right px-5 py-3">Actions</th>
      </tr>
    </thead>
    <tbody>
      {% for product in products %}
      <tr class="border-b border-gray-50 hover:bg-gray-50 transition-colors">
        <td class="px-5 py-3">
          <div class="flex items-center gap-3">
            {% if product.image %}
            <img src="{{ product.image.url }}" alt="{{ product.name }}" class="w-10 h-10 object-cover rounded border border-gray-100 flex-shrink-0">
            {% else %}
            <div class="w-10 h-10 rounded border border-gray-100 bg-gray-50 flex items-center justify-center text-gray-300 flex-shrink-0 text-lg">💎</div>
            {% endif %}
            <div>
              <div class="font-medium text-gray-800 text-xs">{{ product.name }}</div>
              <div class="text-[10px] text-gray-400">{{ product.sku or '—' }}</div>
            </div>
          </div>
        </td>
        <td class="px-5 py-3 text-xs text-gray-600">{{ product.category.name if product.category else '—' }}</td>
        <td class="px-5 py-3 text-xs font-medium text-gray-800">₹{{ "{:,.0f}".format(product.price) }}</td>
        <td class="px-5 py-3 text-xs {% if product.stock == 0 %}text-red-500{% elif product.stock < 5 %}text-yellow-600{% else %}text-gray-600{% endif %}">{{ product.stock }}</td>
        <td class="px-5 py-3">
          {% if product.is_active %}
          <span class="text-[9px] uppercase px-2 py-1 rounded-full bg-green-100 text-green-700">Active</span>
          {% else %}
          <span class="text-[9px] uppercase px-2 py-1 rounded-full bg-gray-100 text-gray-500">Draft</span>
          {% endif %}
          {% if product.is_featured %}<span class="ml-1 text-[9px] uppercase px-2 py-1 rounded-full bg-yellow-100 text-yellow-700">Featured</span>{% endif %}
        </td>
        <td class="px-5 py-3 text-right">
          <a href="{{ url('control:product_edit', pk=product.pk) }}" class="text-xs text-blue-600 no-underline hover:underline mr-3">Edit</a>
          <a href="{{ url('store:product', slug=product.slug) }}" class="text-xs text-gray-400 no-underline hover:underline" target="_blank">View →</a>
        </td>
      </tr>
      {% else %}
      <tr><td colspan="6" class="px-5 py-10 text-center text-gray-400 text-sm">No products yet. <a href="{{ url('control:product_add') }}" class="text-blue-600 no-underline hover:underline">Add one</a></td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>

{% if is_paginated %}
<div class="flex justify-center gap-2 mt-5">
  {% if page_obj.has_previous() %}<a href="?page={{ page_obj.previous_page_number() }}" class="px-3 py-1.5 border border-gray-200 rounded text-xs text-gray-600 no-underline hover:border-gray-400">← Prev</a>{% endif %}
  <span class="px-3 py-1.5 text-xs text-gray-500">Page {{ page_obj.number }} / {{ page_obj.paginator.num_pages }}</span>
  {% if page_obj.has_next() %}<a href="?page={{ page_obj.next_page_number() }}" class="px-3 py-1.5 border border-gray-200 rounded text-xs text-gray-600 no-underline hover:border-gray-400">Next →</a>{% endif %}
</div>
{% endif %}
{% endblock %}
