{% extends "base.jinja" %}
{% block title %}Wholesale Enquiry · ORNZA{% endblock %}
{% block body_class %}has-site-header nav-solid{% endblock %}
{% block content %}
<div class="page">
  <div class="page-header">
    <div class="badge">B2B &amp; Bulk Orders</div>
    <h1 class="page-title">Wholesale Enquiry</h1>
    <p class="page-desc">Partner with ORNZA for bulk orders, bridal collections, and retail distribution across India.</p>
  </div>
  <div class="contact-section" style="max-width:860px;margin:0 auto 80px;">
    <div class="ornza-tw grid grid-cols-1 md:grid-cols-2 gap-8 mb-10">
      <div class="bg-ivory-alt border border-gold/15 rounded-lg p-6">
        <div class="text-2xl mb-3">💎</div>
        <h3 class="font-display text-lg text-espresso mb-2">Minimum Order Quantity</h3>
        <p class="text-sm text-taupe leading-relaxed">Minimum order: ₹10,000 per category. Mix-and-match across collections allowed.</p>
      </div>
      <div class="bg-ivory-alt border border-gold/15 rounded-lg p-6">
        <div class="text-2xl mb-3">🏷️</div>
        <h3 class="font-display text-lg text-espresso mb-2">Wholesale Pricing</h3>
        <p class="text-sm text-taupe leading-relaxed">Trade pricing available — up to 35% off retail. Pricing shared after verification.</p>
      </div>
      <div class="bg-ivory-alt border border-gold/15 rounded-lg p-6">
        <div class="text-2xl mb-3">🎁</div>
        <h3 class="font-display text-lg text-espresso mb-2">Custom Bridal Sets</h3>
        <p class="text-sm text-taupe leading-relaxed">Custom bridal jewellery sets for weddings, boutiques, and gifting companies.</p>
      </div>
      <div class="bg-ivory-alt border border-gold/15 rounded-lg p-6">
        <div class="text-2xl mb-3">🚚</div>
        <h3 class="font-display text-lg text-espresso mb-2">Pan-India Shipping</h3>
        <p class="text-sm text-taupe leading-relaxed">Bulk shipments to all major cities. Special packaging for resellers available.</p>
      </div>
    </div>

    <div class="contact-form-container">
      <h2 class="contact-block-title">Submit Wholesale Enquiry</h2>
      <form method="post" action="{{ url('store:wholesale') }}">
        {{ csrf_input }}
        <div class="form-grid">
          <div class="form-group"><label>Business / Store Name</label><input type="text" name="business_name" class="form-input" placeholder="e.g. Meera Jewels" required></div>
          <div class="form-group"><label>Contact Person</label><input type="text" name="contact_name" class="form-input" placeholder="Your name" required></div>
          <div class="form-group"><label>Phone / WhatsApp</label><input type="tel" name="phone" class="form-input" placeholder="+91 98765 43210" required></div>
          <div class="form-group"><label>Email</label><input type="email" name="email" class="form-input" placeholder="business@email.com" required></div>
          <div class="form-group full-width"><label>City &amp; State</label><input type="text" name="location" class="form-input" placeholder="e.g. Ahmedabad, Gujarat" required></div>
          <div class="form-group full-width"><label>Tell Us What You Need</label><textarea name="message" class="form-input form-textarea" placeholder="Categories interested in, estimated monthly volume, any specific requirements..."></textarea></div>
        </div>
        <button type="submit" class="form-submit-btn">Submit Enquiry</button>
      </form>
    </div>
  </div>
</div>
{% endblock %}
