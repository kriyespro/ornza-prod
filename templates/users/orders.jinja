{% extends "base.jinja" %}
{% block title %}My Orders · ORNZA{% endblock %}
{% block body_class %}has-site-header nav-solid{% endblock %}

{% block content %}
<main class="pt-28 pb-16 px-4 md:px-8 max-w-4xl mx-auto">
  <div class="flex items-center gap-4 mb-8">
    <a href="{{ url('users:dashboard') }}" class="text-taupe hover:text-gold-deep text-xs no-underline">← Dashboard</a>
    <div>
      <div class="text-[9px] tracking-[0.3em] uppercase text-gold mb-0.5">Account</div>
      <h1 class="font-display text-2xl text-espresso font-light">My Orders</h1>
    </div>
  </div>

  {% if orders %}
  <div class="space-y-4">
    {% for order in orders %}
    <div class="bg-white border border-gold/15 rounded-lg p-5 hover:border-gold/30 transition-colors">
      <div class="flex items-start justify-between gap-4 flex-wrap">
        <div>
          <a href="{{ url('orders:detail', order_number=order.order_number) }}" class="font-display text-base text-espresso no-underline hover:text-gold-deep">{{ order.order_number }}</a>
          <div class="text-xs text-taupe mt-1">{{ order.created_at.strftime('%d %B %Y') }}</div>
          <div class="text-xs text-taupe mt-0.5">{{ order.items.count() }} item{{ 's' if order.items.count() != 1 }}</div>
        </div>
        <div class="text-right">
          <div class="font-display text-base text-espresso">₹{{ "{:,.0f}".format(order.total) }}</div>
          <span class="inline-block mt-1 text-[9px] uppercase tracking-wide px-2 py-1 rounded
            {% if order.status == 'delivered' %}bg-green-100 text-green-700
            {% elif order.status == 'shipped' %}bg-blue-100 text-blue-700
            {% elif order.status == 'cancelled' %}bg-red-100 text-red-700
            {% else %}bg-gold/10 text-espresso{% endif %}">
            {{ order.status }}
          </span>
        </div>
      </div>
      <div class="mt-3 flex gap-3 flex-wrap">
        <a href="{{ url('orders:detail', order_number=order.order_number) }}" class="text-[9px] tracking-[0.15em] uppercase text-gold-deep no-underline hover:underline">View Details →</a>
        {% if order.status not in ['delivered', 'cancelled'] %}
        <a href="{{ url('store:track_order') }}?order_number={{ order.order_number }}" class="text-[9px] tracking-[0.15em] uppercase text-taupe no-underline hover:text-espresso">Track Order →</a>
        {% endif %}
      </div>
    </div>
    {% endfor %}
  </div>
  {% else %}
  <div class="text-center py-20">
    <div class="text-5xl mb-4">📦</div>
    <h2 class="font-display text-xl text-espresso mb-3">No orders yet</h2>
    <p class="text-sm text-taupe mb-8">Your order history will appear here.</p>
    <a href="{{ url('store:collections') }}" class="inline-flex items-center gap-2 bg-espresso text-gold text-[10px] font-bold tracking-[0.2em] uppercase px-6 py-3 rounded-sm no-underline hover:bg-gold hover:text-espresso transition-all">Shop Now</a>
  </div>
  {% endif %}
</main>
{% endblock %}
