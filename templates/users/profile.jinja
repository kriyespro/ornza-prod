{% extends "base.jinja" %}
{% block title %}My Profile · ORNZA{% endblock %}
{% block body_class %}has-site-header nav-solid{% endblock %}

{% block content %}
<main class="pt-28 pb-16 px-4 md:px-8 max-w-2xl mx-auto">
  <div class="flex items-center gap-4 mb-8">
    <a href="{{ url('users:dashboard') }}" class="text-taupe hover:text-gold-deep text-xs no-underline">← Dashboard</a>
    <div>
      <div class="text-[9px] tracking-[0.3em] uppercase text-gold mb-0.5">Account</div>
      <h1 class="font-display text-2xl text-espresso font-light">My Profile</h1>
    </div>
  </div>

  {% if success %}<div class="bg-green-50 border border-green-200 text-green-700 text-sm px-4 py-3 rounded mb-6">Profile updated successfully.</div>{% endif %}

  <div class="bg-white border border-gold/15 rounded-lg p-6">
    <form method="post" action="{{ url('users:profile') }}" enctype="multipart/form-data">
      {{ csrf_input }}
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-5">
        <div>
          <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe mb-2">First Name</label>
          <input type="text" name="first_name" value="{{ user.first_name }}" class="w-full border border-gold/25 rounded px-4 py-3 text-sm text-espresso outline-none focus:border-gold">
        </div>
        <div>
          <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe mb-2">Last Name</label>
          <input type="text" name="last_name" value="{{ user.last_name }}" class="w-full border border-gold/25 rounded px-4 py-3 text-sm text-espresso outline-none focus:border-gold">
        </div>
      </div>
      <div class="mb-5">
        <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe mb-2">Email</label>
        <input type="email" value="{{ user.email }}" disabled class="w-full border border-gold/10 bg-ivory-alt rounded px-4 py-3 text-sm text-taupe">
        <p class="text-[9px] text-taupe mt-1">Email cannot be changed.</p>
      </div>
      <div class="mb-6">
        <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe mb-2">Phone</label>
        <input type="tel" name="phone" value="{% if user.profile %}{{ user.profile.phone }}{% endif %}" class="w-full border border-gold/25 rounded px-4 py-3 text-sm text-espresso outline-none focus:border-gold" placeholder="+91 98765 43210">
      </div>
      <button type="submit" class="bg-espresso text-gold py-3 px-8 text-[10px] font-bold tracking-[0.2em] uppercase rounded transition-all hover:bg-gold hover:text-espresso">
        Save Changes
      </button>
    </form>
  </div>
</main>
{% endblock %}
