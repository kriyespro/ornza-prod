{% extends "control/base_control.jinja" %}
{% block title %}User: {{ target_user.username }}{% endblock %}
{% block page_title %}User Detail{% endblock %}

{% block content %}
<div class="mb-5">
  <a href="{{ url('control:users') }}" class="text-xs text-gray-500 no-underline hover:text-gray-800">← Back to Users</a>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <!-- User Profile -->
  <div class="bg-white rounded-xl border border-gray-200 p-6">
    <div class="flex items-center gap-4 mb-5">
      <div class="w-14 h-14 rounded-full bg-gradient-to-br from-yellow-400 to-amber-700 flex items-center justify-center text-white text-xl font-bold flex-shrink-0">
        {{ target_user.username[0]|upper }}
      </div>
      <div>
        <div class="font-semibold text-gray-800">{{ target_user.username }}</div>
        {% if target_user.get_full_name() %}<div class="text-xs text-gray-500">{{ target_user.get_full_name() }}</div>{% endif %}
      </div>
    </div>
    <div class="space-y-3 text-sm">
      <div class="flex justify-between"><span class="text-gray-500">Email</span><span class="text-gray-800">{{ target_user.email or '—' }}</span></div>
      <div class="flex justify-between"><span class="text-gray-500">Joined</span><span class="text-gray-800">{{ target_user.date_joined.strftime('%d %b %Y') }}</span></div>
      <div class="flex justify-between"><span class="text-gray-500">Last Login</span><span class="text-gray-800">{{ target_user.last_login.strftime('%d %b %Y') if target_user.last_login else '—' }}</span></div>
      <div class="flex justify-between"><span class="text-gray-500">Staff</span><span>{% if target_user.is_staff %}<span class="text-[9px] uppercase px-2 py-1 bg-blue-100 text-blue-700 rounded">Yes</span>{% else %}No{% endif %}</span></div>
      <div class="flex justify-between"><span class="text-gray-500">Status</span><span>{% if target_user.is_active %}<span class="text-[9px] uppercase px-2 py-1 bg-green-100 text-green-700 rounded">Active</span>{% else %}<span class="text-[9px] uppercase px-2 py-1 bg-red-100 text-red-700 rounded">Banned</span>{% endif %}</span></div>
    </div>
    <!-- Toggle Ban -->
    <form method="post" action="{{ url('sd:auth_user_change', object_id=target_user.pk) }}" class="mt-5">
      <a href="/sd/auth/user/{{ target_user.pk }}/change/" target="_blank" class="block w-full text-center border border-gray-200 text-gray-600 text-xs py-2.5 rounded-lg no-underline hover:border-gray-400">Edit in Django Admin →</a>
    </form>
  </div>

  <!-- Orders -->
  <div class="lg:col-span-2 bg-white rounded-xl border border-gray-200 p-6">
    <h2 class="font-semibold text-gray-800 mb-4">Order History ({{ orders|length }})</h2>
    {% if orders %}
    <table class="w-full text-sm">
      <thead>
        <tr class="text-[10px] tracking-wider uppercase text-gray-400 border-b border-gray-100">
          <th class="text-left pb-3">Order #</th>
          <th class="text-left pb-3">Status</th>
          <th class="text-left pb-3">Date</th>
          <th class="text-right pb-3">Total</th>
        </tr>
      </thead>
      <tbody>
        {% for order in orders %}
        <tr class="border-b border-gray-50 hover:bg-gray-50">
          <td class="py-3"><a href="{{ url('control:order_detail', pk=order.pk) }}" class="text-blue-600 no-underline hover:underline text-xs">{{ order.order_number }}</a></td>
          <td class="py-3"><span class="text-[9px] uppercase px-2 py-1 rounded bg-gray-100 text-gray-600">{{ order.status }}</span></td>
          <td class="py-3 text-xs text-gray-400">{{ order.created_at.strftime('%d %b %Y') }}</td>
          <td class="py-3 text-xs text-right font-medium">₹{{ "{:,.0f}".format(order.total) }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% else %}
    <p class="text-gray-400 text-sm">No orders for this user.</p>
    {% endif %}
  </div>
</div>
{% endblock %}
