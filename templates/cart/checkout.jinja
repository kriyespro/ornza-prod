{% extends "base.jinja" %}

{% block title %}Checkout · ORNZA{% endblock %}
{% block body_class %}has-site-header nav-solid{% endblock %}

{% block content %}
<main class="pt-28 pb-16 px-4 md:px-8 max-w-5xl mx-auto">
  <div class="mb-8">
    <div class="text-[9px] tracking-[0.3em] uppercase text-gold mb-1">Almost There</div>
    <h1 class="font-display text-3xl text-espresso font-light">Checkout</h1>
  </div>

  <form method="post" action="{{ url('cart:checkout_confirm') }}">
    {{ csrf_input }}
    {% if messages %}
    <div class="mb-6 space-y-2">
      {% for message in messages %}
      <div class="rounded border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">{{ message }}</div>
      {% endfor %}
    </div>
    {% endif %}
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Shipping Details -->
      <div class="lg:col-span-2 space-y-5">
        <h2 class="font-display text-xl text-espresso">Shipping Details</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe mb-2">Full Name *</label>
            <input type="text" name="full_name" required class="w-full border border-gold/25 rounded px-4 py-3 text-sm text-espresso outline-none focus:border-gold">
          </div>
          <div>
            <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe mb-2">Phone *</label>
            <input type="tel" name="phone" required class="w-full border border-gold/25 rounded px-4 py-3 text-sm text-espresso outline-none focus:border-gold">
          </div>
        </div>
        <div>
          <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe mb-2">Email</label>
          <input type="email" name="email" value="{% if user.is_authenticated %}{{ user.email }}{% endif %}" class="w-full border border-gold/25 rounded px-4 py-3 text-sm text-espresso outline-none focus:border-gold">
        </div>
        <div>
          <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe mb-2">Address Line 1 *</label>
          <input type="text" name="address_line1" required class="w-full border border-gold/25 rounded px-4 py-3 text-sm text-espresso outline-none focus:border-gold">
        </div>
        <div>
          <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe mb-2">Address Line 2</label>
          <input type="text" name="address_line2" class="w-full border border-gold/25 rounded px-4 py-3 text-sm text-espresso outline-none focus:border-gold">
        </div>
        <div class="grid grid-cols-3 gap-4">
          <div>
            <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe mb-2">City *</label>
            <input type="text" name="city" required class="w-full border border-gold/25 rounded px-4 py-3 text-sm text-espresso outline-none focus:border-gold">
          </div>
          <div>
            <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe mb-2">State *</label>
            <input type="text" name="state" required class="w-full border border-gold/25 rounded px-4 py-3 text-sm text-espresso outline-none focus:border-gold">
          </div>
          <div>
            <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe mb-2">Pincode *</label>
            <input type="text" name="pincode" required class="w-full border border-gold/25 rounded px-4 py-3 text-sm text-espresso outline-none focus:border-gold">
          </div>
        </div>

        <h2 class="font-display text-xl text-espresso pt-4">Payment Method</h2>
        <div class="space-y-3">
          <label class="flex items-center gap-3 p-4 border border-gold/25 rounded cursor-pointer hover:border-gold transition-colors">
            <input type="radio" name="payment_method" value="cod" checked class="text-gold">
            <div>
              <div class="text-sm font-medium text-espresso">Cash on Delivery</div>
              <div class="text-xs text-taupe">Pay when you receive your order</div>
            </div>
          </label>
          <label class="flex items-center gap-3 p-4 border border-gold/25 rounded cursor-pointer hover:border-gold transition-colors">
            <input type="radio" name="payment_method" value="upi" class="text-gold">
            <div>
              <div class="text-sm font-medium text-espresso">UPI / Online Payment</div>
              <div class="text-xs text-taupe">Pay now via UPI, card, or net banking</div>
            </div>
          </label>
        </div>
      </div>

      <!-- Order Summary -->
      <div>
        <div class="bg-ivory-alt border border-gold/15 rounded-lg p-6 sticky top-32">
          <h2 class="font-display text-xl text-espresso mb-5">Order Summary</h2>
          {% for item in cart.items.select_related('product').all() %}
          <div class="flex justify-between text-sm py-2 border-b border-gold/10">
            <span class="text-taupe">{{ item.product.name }} × {{ item.quantity }}</span>
            <span class="text-espresso">₹{{ "{:,.0f}".format(item.subtotal) }}</span>
          </div>
          {% endfor %}
          <div class="space-y-2 mt-4 text-sm">
            <div class="flex justify-between text-taupe">
              <span>Subtotal</span><span>₹{{ "{:,.0f}".format(cart.total) }}</span>
            </div>
            <div class="flex justify-between text-taupe">
              <span>Shipping</span>
              <span>{% if cart.total >= 999 %}<span class="text-green-600">Free</span>{% else %}₹99{% endif %}</span>
            </div>
            <div class="border-t border-gold/15 pt-3 flex justify-between font-display text-base text-espresso font-medium">
              <span>Total</span>
              <span>₹{{ "{:,.0f}".format(cart.total + (0 if cart.total >= 999 else 99)) }}</span>
            </div>
          </div>
          <button type="submit" class="w-full mt-5 bg-espresso text-gold py-3.5 text-[10px] font-bold tracking-[0.2em] uppercase rounded transition-all hover:bg-gold hover:text-espresso">
            Place Order
          </button>
          <p class="text-[9px] text-taupe/70 text-center mt-3">By placing your order you agree to our terms & conditions.</p>
        </div>
      </div>
    </div>
  </form>
</main>
{% endblock %}
