{% extends "base.jinja" %}
{% block title %}Shipping Information · ORNZA{% endblock %}
{% block body_class %}has-site-header nav-solid{% endblock %}
{% block content %}
<div class="page">
  <div class="page-header">
    <div class="badge">Delivery</div>
    <h1 class="page-title">Shipping Information</h1>
    <p class="page-desc">Fast, insured delivery across India. Free shipping on orders above ₹999.</p>
  </div>
  <div class="contact-section" style="max-width:760px;margin:0 auto 80px;">
    <div class="contact-info-panel" style="padding:32px;">
      <h2 class="contact-block-title">Delivery Timelines</h2>
      <ul style="list-style:disc;padding-left:20px;color:var(--color-text-muted);line-height:1.9;font-size:14px;margin-bottom:20px;">
        <li>Metro cities (Mumbai, Delhi, Bangalore, etc.): 2–3 business days</li>
        <li>Other cities and towns: 3–5 business days</li>
        <li>Remote areas: Up to 7 business days</li>
        <li>International: 7–12 business days (coming soon)</li>
      </ul>
      <h2 class="contact-block-title">Shipping Charges</h2>
      <ul style="list-style:disc;padding-left:20px;color:var(--color-text-muted);line-height:1.9;font-size:14px;margin-bottom:20px;">
        <li>Free shipping on all orders above ₹999</li>
        <li>Flat ₹99 shipping on orders below ₹999</li>
        <li>COD (Cash on Delivery) available across India</li>
      </ul>
      <h2 class="contact-block-title">Track Your Order</h2>
      <p class="showroom-detail" style="line-height:1.8;margin-bottom:16px;">Once dispatched, you'll receive a tracking link via SMS and email. You can also track directly on our website.</p>
      <a href="{{ url('store:track_order') }}" class="form-submit-btn" style="display:inline-block;text-align:center;">Track My Order</a>
    </div>
  </div>
</div>
{% endblock %}
