{% extends "base.jinja" %}

{% block title %}Our Story · ORNZA — Premium Jewellery Surat{% endblock %}
{% block meta_description %}ORNZA was born in Surat in 2025 to democratize luxury jewellery. Learn our story, crafting process, and values.{% endblock %}
{% block body_class %}has-site-header nav-solid{% endblock %}

{% block content %}
<div class="page" style="padding-top:20px;">
  <div class="page-header">
    <div class="badge">The Legend of ORNZA</div>
    <h1 class="page-title">Story &amp; Heritage</h1>
    <p class="page-desc">Bridging the gap between the staggering cost of gold and the desire for high-fashion, uncompromising luxury.</p>
  </div>

  <div class="about-section">
    <div class="about-intro-grid">
      <div class="about-story-text">
        <p>Established in 2025 in <strong>Surat, India</strong> — the absolute heart of the global diamond cutting and trade industry — ORNZA was born with a singular, clear vision: to democratize high-luxury jewelry.</p>
        <p>For generations, the weight and allure of gold and diamonds represented ultimate grace, but remained locked behind steep pricing. We believed that elegance should be an everyday experience, not an occasional compromise.</p>
        <p>By combining Surat's century-old stone-setting heritage with state-of-the-art metallurgical plating, we created a new standard in artificial jewellery. Our pieces carry the exact density, micro-engraving, and refractive index of fine heirloom gold, at a fraction of the cost.</p>
      </div>
      <div class="about-story-visual">
        <img src="{{ static('images/necklace_preview.png') }}" alt="ORNZA Craftsmanship Showcase">
      </div>
    </div>

    <div class="about-features-grid">
      <div class="about-feature-card">
        <div class="about-feature-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
        </div>
        <h3 class="about-feature-title">Surat Karigars</h3>
        <p class="about-feature-desc">Our designs are hand-cast and set by local master artisans whose families have set gold and diamonds for generations.</p>
      </div>
      <div class="about-feature-card">
        <div class="about-feature-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v8M8 12h8"/></svg>
        </div>
        <h3 class="about-feature-title">Ethical Sourcing</h3>
        <p class="about-feature-desc">We use only conflict-free laboratory moissanites, Swiss-cut cubic zirconia, and recycled sterling silver base alloys.</p>
      </div>
      <div class="about-feature-card">
        <div class="about-feature-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12,2 15,9 22,9 17,14 19,21 12,17 5,21 7,14 2,9 9,9"/></svg>
        </div>
        <h3 class="about-feature-title">Anti-Tarnish Plating</h3>
        <p class="about-feature-desc">Layered in thick 18k and 22k gold vermeil, finished with a vacuum-sealed coating to guard against water and sweat.</p>
      </div>
    </div>

    <div class="atelier-showcase">
      <h2 class="atelier-title">The Crafting Process</h2>
      <p class="atelier-desc">Each ORNZA piece goes through a 9-step production lifecycle: starting with 3D CAD modeling, moving to traditional hand-carved wax masters, high-density metal casting, mirror polishing, electrochemical plating (5 layers of 18k or 22k gold), microscopic prong-setting of individual stones, and lastly, dual-stage protective curing.</p>
    </div>

    <div class="ornza-tw mt-16 text-center">
      <a href="{{ url('store:collections') }}" class="inline-flex items-center gap-3 bg-espresso text-gold text-[10px] font-bold tracking-[0.2em] uppercase px-8 py-4 rounded-sm no-underline hover:bg-gold hover:text-espresso transition-all">
        Shop Our Collections →
      </a>
    </div>
  </div>

  <div class="social-row">
    <a href="https://instagram.com/ornza.com2026" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="Instagram">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r=".5" fill="currentColor"/></svg>
    </a>
    <a href="https://wa.me/919999999999" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="WhatsApp">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
    </a>
  </div>
</div>

