{% extends "control/base_control.jinja" %}
{% block title %}Order {{ order.order_number }}{% endblock %}
{% block page_title %}Order Detail{% endblock %}

{% block content %}
<div class="mb-4"><a href="{{ url('control:orders') }}" class="text-xs text-gray-500 no-underline hover:text-gray-800">← Back to Orders</a></div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <!-- Order Info -->
  <div class="bg-white rounded-xl border border-gray-200 p-6">
    <h2 class="font-semibold text-gray-800 mb-4">{{ order.order_number }}</h2>
    <div class="space-y-3 text-sm mb-5">
      <div class="flex justify-between"><span class="text-gray-500">Status</span><span class="text-[9px] uppercase px-2 py-1 rounded bg-gray-100">{{ order.status }}</span></div>
      <div class="flex justify-between"><span class="text-gray-500">Payment</span><span>{{ order.payment_method|upper }} {% if order.is_paid %}<span class="text-[9px] text-green-600">✓ Paid</span>{% else %}<span class="text-[9px] text-red-500">Unpaid</span>{% endif %}</span></div>
      <div class="flex justify-between"><span class="text-gray-500">Subtotal</span><span>₹{{ "{:,.0f}".format(order.subtotal) }}</span></div>
      <div class="flex justify-between"><span class="text-gray-500">Shipping</span><span>{% if order.shipping_charge == 0 %}Free{% else %}₹{{ "{:,.0f}".format(order.shipping_charge) }}{% endif %}</span></div>
      <div class="flex justify-between font-semibold border-t pt-3"><span>Total</span><span>₹{{ "{:,.0f}".format(order.total) }}</span></div>
    </div>
    {% if order.tracking_number %}
    <div class="text-xs text-gray-500">Tracking: <span class="font-medium text-gray-800">{{ order.tracking_number }}</span></div>
    {% endif %}
    <a href="/sd/orders/order/{{ order.pk }}/change/" class="block mt-4 text-center border border-gray-200 text-gray-600 text-xs py-2.5 rounded-lg no-underline hover:border-gray-400" target="_blank">Edit in Django Admin →</a>
  </div>

  <!-- Items + Address -->
  <div class="lg:col-span-2 space-y-5">
    <div class="bg-white rounded-xl border border-gray-200 p-6">
      <h2 class="font-semibold text-gray-800 mb-4">Items</h2>
      {% for item in order.items.all() %}
      <div class="flex justify-between py-2.5 border-b border-gray-50 text-sm">
        <span class="text-gray-700">{{ item.product_name }} × {{ item.quantity }}</span>
        <span class="font-medium text-gray-800">₹{{ "{:,.0f}".format(item.subtotal) }}</span>
      </div>
      {% endfor %}
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-6">
      <h2 class="font-semibold text-gray-800 mb-4">Shipping To</h2>
      <div class="text-sm text-gray-600 space-y-1">
        <div class="font-medium text-gray-800">{{ order.full_name }}</div>
        <div>{{ order.address_line1 }}{% if order.address_line2 %}, {{ order.address_line2 }}{% endif %}</div>
        <div>{{ order.city }}, {{ order.state }} - {{ order.pincode }}</div>
        <div>📞 {{ order.phone }}</div>
        {% if order.email %}<div>✉ {{ order.email }}</div>{% endif %}
      </div>
    </div>
  </div>
</div>
{% endblock %}
